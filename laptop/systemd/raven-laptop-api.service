[Unit]
Description=Raven Laptop Management API
After=network.target wg-quick@wg0.service
Requires=wg-quick@wg0.service
[Service]
Type=simple
User=your-username
WorkingDirectory=/path/to/raven-student/laptop
Environment="PATH=/path/to/raven-student/laptop/venv/bin"
ExecStart=/path/to/raven-student/laptop/venv/bin/python /path/to/raven-student/laptop/app.py
Restart=always
RestartSec=5
[Install]
WantedBy=multi-user.target
