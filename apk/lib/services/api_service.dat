import 'dart:convert';
import 'dart:typed_data';
import 'package:http/http.dart' as http;
import 'package:pointycastle/signers/ed25519_signer.dart';
import 'package:pointycastle/api.dart';
import 'package:pointycastle/asymmetric/ed25519.dart';
import 'package:convert/convert.dart';
import 'package:flutter/services.dart' show rootBundle;

class ApiService {
  static const _baseUrl = String.fromEnvironment('RAVEN_API_URL', defaultValue: 'https://api.ravenstudent.com');
  static Uint8List? _publicKeyBytes;

  static Future<Uint8List> _loadPublicKey() async {
    if (_publicKeyBytes != null) return _publicKeyBytes!;
    final raw = await rootBundle.load('assets/wg_public_key.raw');
    _publicKeyBytes = raw.buffer.asUint8List();
    return _publicKeyBytes!;
  }

  static Future<Map<String, dynamic>> activateVoucher(String code) async {
    final res = await http.post(Uri.parse('$_baseUrl/api/vouchers/activate'), headers: {'Content-Type': 'application/json'}, body: jsonEncode({'voucher_code': code}));
    if (res.statusCode != 200) throw Exception('Activation failed');
    final data = jsonDecode(res.body);
    if (!data['success']) throw Exception(data['message'] ?? 'Unknown error');
    return data;
  }

  static Future<Map<String, dynamic>> getSessionStatus(String token) async {
    final res = await http.get(Uri.parse('$_baseUrl/api/session/status'), headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer $token'});
    if (res.statusCode != 200) throw Exception('Status check failed');
    final data = jsonDecode(res.body);
    if (!data['success']) throw Exception(data['message'] ?? 'Unknown error');
    return data;
  }

  static Future<void> disconnectSession(String token) async {
    final res = await http.post(Uri.parse('$_baseUrl/api/session/disconnect'), headers: {'Content-Type': 'application/json', 'Authorization': 'Bearer $token'});
    if (res.statusCode != 200) throw Exception('Disconnect failed');
  }

  static Future<bool> verifyConfigSignature(String configText, String signatureHex) async {
    try {
      final publicKeyBytes = await _loadPublicKey();
      if (publicKeyBytes.length != 32) {
        print('❌ Invalid public key length: ${publicKeyBytes.length}');
        return false;
      }
      
      final pubKey = Ed25519PublicKeyParameters(publicKeyBytes);
      final signer = Ed25519Signer();
      signer.init(false, ParametersWithNull(pubKey));
      
      final sigBytes = hex.decode(signatureHex);
      if (sigBytes.length != 64) {
        print('❌ Invalid signature length: ${sigBytes.length}');
        return false;
      }
      
      final message = Uint8List.fromList(utf8.encode(configText));
      final isValid = signer.verifySignature(message, sigBytes);
      print('✅ Signature valid: $isValid');
      return isValid;
    } catch (e, stackTrace) {
      print('❌ Signature verification failed: $e');
      print('Stack: $stackTrace');
      return false;
    }
  }
}
