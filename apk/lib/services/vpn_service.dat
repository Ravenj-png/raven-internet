import 'package:wireguard_flutter/wireguard_flutter.dart';
class VpnService {
  static final _wg = WireguardFlutter();
  static Future<void> connect(String configText) async {
    await _wg.initialize();
    await _wg.importConfig(name: 'Raven Student', config: configText);
    await _wg.turnOn();
  }
  static Future<void> disconnect() async { await _wg.turnOff(); }
}
